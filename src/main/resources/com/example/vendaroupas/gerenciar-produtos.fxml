<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vendaroupas.controller.ProdutoController" style="-fx-background-color: #f4f4f9;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" prefWidth="320.0">
        <Label text="Cadastro de Produto" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <VBox spacing="5.0">
            <Label text="Nome:" textFill="#7f8c8d" />
            <TextField fx:id="txtNome" promptText="Ex: Camiseta Polo Preta" style="-fx-pref-height: 30;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Quantidade:" textFill="#7f8c8d" />
            <TextField fx:id="txtQuantidade" promptText="0" style="-fx-pref-height: 30;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Categoria:" textFill="#7f8c8d" />
            <ComboBox fx:id="cbCategoria" promptText="Selecione..." style="-fx-pref-height: 30; -fx-pref-width: 300;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Tamanho:" textFill="#7f8c8d" />
            <TextField fx:id="txtTamanho" promptText="Ex: M, GG, 42" style="-fx-pref-height: 30;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Cor:" textFill="#7f8c8d" />
            <TextField fx:id="txtCor" promptText="Ex: Azul Marinho" style="-fx-pref-height: 30;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Preço:" textFill="#7f8c8d" />
            <TextField fx:id="txtPreco" promptText="0.00" style="-fx-pref-height: 30;" />
        </VBox>

        <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="btnLimpar" onAction="#aoLimpar" text="Limpar" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 32;" />
            <Button fx:id="btnSalvar" onAction="#aoSalvar" text="Salvar" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-height: 32; -fx-pref-width: 80;" />
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Button text="Voltar para vendas" onAction="#irParaVendas" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>
    </VBox>

    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <Label text="Produtos em Estoque" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <TableView fx:id="tabelaProdutos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colNome" prefWidth="200.0" text="Nome" />
                <TableColumn fx:id="colQuantidade" prefWidth="200.0" text="Quantidade" />
                <TableColumn fx:id="colCategoria" prefWidth="100.0" text="Categoria" />
                <TableColumn fx:id="colTamanho" prefWidth="80.0" text="Tamanho" />
                <TableColumn fx:id="colCor" prefWidth="100.0" text="Cor" />
                <TableColumn fx:id="colPreco" prefWidth="90.0" text="Preço" />
            </columns>
        </TableView>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Button fx:id="btnEditar" onAction="#aoEditar" text="Editar Selecionado" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 32;" />
            <Button fx:id="btnExcluir" onAction="#aoExcluir" text="Excluir Selecionado" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 32;" />
        </HBox>
    </VBox>
</HBox>