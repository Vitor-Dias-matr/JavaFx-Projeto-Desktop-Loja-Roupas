<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" prefWidth="1024.0" prefHeight="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vendaroupas.controller.VendaController" style="-fx-background-color: #f4f4f9;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" prefWidth="350.0">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Efetuar Venda" textFill="#2c3e50" HBox.hgrow="ALWAYS">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
            <Button fx:id="btnGerenciarProdutos" onAction="#irParaGerenciarProdutos" text="Estoque" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>

        <VBox spacing="5.0">
            <Label text="Selecionar Produto:" textFill="#7f8c8d" />
            <ComboBox fx:id="cbProduto" promptText="Selecione o produto..." style="-fx-pref-height: 35; -fx-pref-width: 310;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Quantidade:" textFill="#7f8c8d" />
            <TextField fx:id="txtQuantidade" promptText="1" text="1" style="-fx-pref-height: 35;" />
        </VBox>

        <Button fx:id="btnAdicionar" onAction="#aoAdicionarProduto" text="Adicionar à Venda" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-pref-height: 35; -fx-pref-width: 310;" />

        <VBox spacing="5.0" style="-fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
            <Label text="Cupom de Desconto:" textFill="#7f8c8d" />
            <HBox spacing="10.0">
                <TextField fx:id="txtCupom" promptText="CÓDIGO" style="-fx-pref-height: 32;" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnAplicarCupom" onAction="#aoAplicarCupom" text="Aplicar" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-cursor: hand; -fx-pref-height: 32;" />
            </HBox>
        </VBox>

        <VBox spacing="5.0">
            <Label text="Forma de Pagamento:" textFill="#7f8c8d" />
            <ComboBox fx:id="cbFormaPagamento" promptText="Selecione..." style="-fx-pref-height: 35; -fx-pref-width: 310;" />
        </VBox>
    </VBox>

    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <Label text="Produtos na Venda (Carrinho)" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <TableView fx:id="tabelaCarrinho" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8;">
            <columns>
                <TableColumn fx:id="colItemProduto" prefWidth="250.0" text="Produto" />
                <TableColumn fx:id="colItemPrecoUnitario" prefWidth="110.0" text="Preço Unit." />
                <TableColumn fx:id="colItemQuantidade" prefWidth="90.0" text="Qtd." />
                <TableColumn fx:id="colItemTotal" prefWidth="120.0" text="Total" />
            </columns>
        </TableView>

        <HBox spacing="20.0" alignment="CENTER_RIGHT" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
            <VBox spacing="5.0" alignment="CENTER_LEFT">
                <Label text="Subtotal: R$ 0,00" fx:id="lblSubtotal" textFill="#7f8c8d"><font><Font size="14.0" /></font></Label>
                <Label text="Desconto: R$ 0,00" fx:id="lblDesconto" textFill="#e74c3c"><font><Font size="14.0" /></font></Label>
                <Label text="TOTAL: R$ 0,00" fx:id="lblTotal" textFill="#2c3e50"><font><Font name="System Bold" size="20.0" /></font></Label>
            </VBox>
            <VBox alignment="CENTER">
                <Button fx:id="btnFinalizarVenda" onAction="#aoFinalizarVenda" text="FINALIZAR VENDA" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand; -fx-pref-height: 50; -fx-pref-width: 180;" />
            </VBox>
        </HBox>
    </VBox>
</HBox>